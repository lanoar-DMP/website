# PostgreSQL
POSTGRES_USER=holyterminal
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=holyterminal

# FRED API
FRED_API_KEY=your_fred_api_key_here

# Yahoo Finance (no auth needed, but document it)
# YFINANCE_NO_AUTH=true

# CoinMarketCap
CMC_API_KEY=your_cmc_api_key_here

# CoinGecko (no auth for free tier; optional Pro API key for higher rate limits)
COINGECKO_API_KEY=your_coingecko_api_key_here

# DeFiLlama (no auth, but document it)
# DEFILLAMA_NO_AUTH=true

# Infura RPC (primary on-chain provider)
INFURA_API_KEY=your_infura_api_key_here

# Alchemy RPC (fallback on-chain provider)
ALCHEMY_API_KEY=your_alchemy_key_here

# Claude API
ANTHROPIC_API_KEY=your_anthropic_key_here

# SEC EDGAR (no auth, but document it)
# SEC_EDGAR_NO_AUTH=true

# Blnk Ledger
BLNK_API_URL=http://blnk:7789
BLNK_API_KEY=your_blnk_api_key_here
# Blnk auto-generates a ledger called "holyterminal_ledger" on first boot.
# The data-ingestion service will create it automatically via the REST API.

# App
NEXT_PUBLIC_APP_NAME=HolyTerminal
